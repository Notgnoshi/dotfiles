#!/bin/bash
set -o errexit
set -o pipefail
set -o nounset
set -o noclobber

## Print the (first) selected line
SINGLE_SELECTION="echo {}"
## Print all selected lines, one per line
MULTI_SELECTION="printf '%s\n' {+}"

# Aligned, colored: repository (cyan), tag (yellow), image id (grey). Padding and
# color are applied together so column widths don't count the ANSI bytes; fzf
# --ansi strips the color back out before the binds' awk filters see the line.
list-images() {
    docker images --format '{{.Repository}} {{.Tag}} {{.ID}}' | awk '
        { repo[NR]=$1; tag[NR]=$2; id[NR]=$3
          if (length($1) > rw) rw = length($1)
          if (length($2) > tw) tw = length($2) }
        END {
          for (i = 1; i <= NR; i++)
            printf "\033[36m%-*s\033[0m  \033[33m%-*s\033[0m  \033[90m%s\033[0m\n", \
                   rw, repo[i], tw, tag[i], id[i]
        }'
}

filter-image-hash() {
    awk '{ print $3 }'
}

filter-repository-tag() {
    awk '{ print $1 ":" $2 }'
}

__FZF_LIST_IMAGES="list-images"
__FZF_ARGS=(
    # TODO: What's a useful preview?
    # --preview-label="[ Image ]"
    # --preview="echo preview"
    # --preview-window="top,30%"
    --header="<enter> run   <del> delete   <ctrl-p> pull   <ctrl-y> copy

"

    # Run the image in docker-cwd
    --bind="enter:become(
        $(declare -f filter-image-hash)
        $SINGLE_SELECTION | filter-image-hash | xargs -o docker-cwd
    )"

    # Delete
    --bind="del:execute(
        $(declare -f filter-image-hash)
        $MULTI_SELECTION | filter-image-hash | xargs docker rmi
    )+reload($(declare -f list-images); list-images)"

    # Pull
    --bind="ctrl-p:become(
        $(declare -f filter-repository-tag)
        $MULTI_SELECTION | filter-repository-tag | xargs --max-lines=1 docker pull
    )"

    # Copy image
    --bind="ctrl-y:execute(
        $(declare -f filter-repository-tag)
        $MULTI_SELECTION | filter-repository-tag | clip
    )"
)

if ! $__FZF_LIST_IMAGES | fzf \
    --ansi \
    --no-sort \
    --reverse \
    --exit-0 \
    --multi \
    "${__FZF_ARGS[@]}"; then

    # 130 means user exit
    if [[ $? -eq 130 ]]; then
        true
    fi
fi
