#!/bin/bash
set -o errexit
set -o pipefail
set -o nounset
#set -o noclobber

CARGO_HOME="${CARGO_HOME:-$HOME/.cargo/}"
RUSTUP_HOME="${RUSTUP_HOME:-$HOME/.rustup/}"

echo "$USER::$(id -u):$(id -g)::$HOME:" >/tmp/docker-cwd-passwd

ssh_args=()
if [[ -S "${SSH_AUTH_SOCK:-}" ]]; then
    ssh_args+=(
        --mount "type=bind,src=$SSH_AUTH_SOCK,dst=$SSH_AUTH_SOCK"
        --env "SSH_AUTH_SOCK=$SSH_AUTH_SOCK"
    )
else
    echo "docker-cwd: no SSH_AUTH_SOCK agent available" >&2
fi

rust_args=()
for var in CARGO_HOME RUSTUP_HOME; do
    dir="${!var}"
    if [[ -d "$dir" ]]; then
        rust_args+=(--mount "type=bind,src=$dir,dst=$dir" --env "$var=$dir")
    else
        echo "docker-cwd: $var ($dir) not found, not mounted" >&2
    fi
done

docker run \
    --rm \
    -it \
    --mount "type=bind,src=$PWD,dst=$PWD" \
    --mount "type=bind,src=/tmp/docker-cwd-passwd,dst=/etc/passwd,ro" \
    "${rust_args[@]}" \
    "${ssh_args[@]}" \
    --env "GIT_SSH_COMMAND=ssh -o StrictHostKeyChecking=no" \
    --user "$(id -u):$(id -g)" \
    --workdir "$PWD" \
    "$@"
