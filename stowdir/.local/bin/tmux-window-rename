#!/bin/bash
# Rename a tmux window after its active pane's foreground command or path.
set -o errexit
set -o pipefail
set -o nounset

# Foreground command basenames whose argv is rendered as the window name instead of the path
CMDS=(ssh sshclip)
# If argv[0] is one of these, argv[1] is treated as the effective command (i.e. for shell scripts).
SHELLS=(bash sh dash zsh fish ksh)
# Maximum rendered name length
MAX_LEN=25

# basename that also strips a leading dash so "-bash" becomes "bash"
basename_clean() {
    local -r s="${1##*/}"
    echo "${s#-}"
}

# Check if $1 is in ${@:2}
in_list() {
    local -r needle="$1"
    shift
    local item
    for item in "$@"; do
        [[ "$needle" = "$item" ]] && return 0
    done
    return 1
}

# Print the name of one of the ${CMDS[@]} if it's the active cmdline for the tty
render_cmds() {
    local -r tty="$1"
    [[ -n "$tty" ]] || return 0

    local tpgid
    tpgid=$(ps -o tpgid= -t "${tty#/dev/}" 2>/dev/null | awk 'NR==1 {print $1; exit}' || true)
    [[ "${tpgid:-0}" -gt 0 && -r "/proc/$tpgid/cmdline" ]] || return 0

    local -a argv
    mapfile -d '' -t argv <"/proc/$tpgid/cmdline"
    ((${#argv[@]} > 0)) || return 0

    # Match argv[0]; if argv[0] is a shell wrapper, also try argv[1] (the script).
    local idx=0
    local name
    name=$(basename_clean "${argv[0]}")
    if ! in_list "$name" "${CMDS[@]}"; then
        if ((${#argv[@]} > 1)) && in_list "$name" "${SHELLS[@]}"; then
            name=$(basename_clean "${argv[1]}")
            in_list "$name" "${CMDS[@]}" || return 0
            idx=1
        else
            return 0
        fi
    fi

    if ((${#argv[@]} > idx + 1)); then
        echo "$name ${argv[*]:idx+1}"
    else
        echo "$name"
    fi
}

# Print a short form of the given path
render_path() {
    local -r path="$1"
    local root
    if [[ "$path" = "$HOME" ]]; then
        echo "~"
    elif root=$(git -C "$path" rev-parse --show-toplevel 2>/dev/null); then
        basename "$root"
    else
        basename "$path"
    fi
}

window_id="${1:-}"
if [[ -z "$window_id" ]]; then
    exit 0
fi

IFS=$'\t' read -r PANE_PATH PANE_TTY \
    < <(tmux display-message -p -t "$window_id" $'#{pane_current_path}\t#{pane_tty}')

# First check if we should render the current command, otherwise fallback on the CWD
name=$(render_cmds "$PANE_TTY")
if [[ -z "$name" ]]; then
    name=$(render_path "$PANE_PATH")
fi

tmux rename-window -t "$window_id" "${name:0:MAX_LEN}"
