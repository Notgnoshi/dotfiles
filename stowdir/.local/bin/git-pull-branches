#!/bin/bash
set -o errexit
set -o pipefail
set -o nounset
set -o noclobber

main() {
    local -r branches=("$@")
    local -r remote="${GIT_REMOTE:-origin}"

    git fetch "$remote"

    local -r current_branch="$(git branch --show-current)"
    # Handle the case where we're on a detached HEAD, in which case we want to return to the current
    # revision rather than the current branch.
    local -r saved_ref="${current_branch:-$(git rev-parse HEAD)}"

    local stashed="true"
    if git stash | grep "No local changes to save" >/dev/null; then
        stashed="false"
    fi

    for branch in "${branches[@]}"; do
        git switch "$branch"
        git pull --rebase
    done

    git checkout "$saved_ref"

    if [[ "$stashed" = "true" ]]; then
        git stash pop
    fi
}

main "$@"
