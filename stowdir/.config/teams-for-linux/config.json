{
    "alwaysOnSystemIdle": true,
    "disableNotifications": true,
    "closeAppOnCross": true,
    "disableGlobalShortcuts": [
        "Ctrl+Shift+C",
        "Ctrl+Shift+V"
    ],
    "mqtt": {
        "enabled": true,
        "brokerUrl": "mqtt://localhost:1883",
        "topicPrefix": "bedlam/teams",
        "statusTopic": "status"
    },
    "disableGpu": false,
    "electronCLIFlags": [
        [
            "use-gl",
            "angle"
        ],
        [
            "enable-features",
            "UseOzonePlatform,AcceleratedVideoDecodeLinuxZeroCopyGL,AcceleratedVideoDecodeLinuxGL,AcceleratedVideoEncoder,VaapiIgnoreDriverChecks,WebRTCPipeWireCapturer"
        ],
        "ignore-gpu-blocklist",
        "disable-gpu-driver-bug-workaround"
    ]
}
